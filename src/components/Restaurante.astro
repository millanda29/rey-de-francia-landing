---
import Icono from "./Icono.astro";
---

<section class="restaurante" id="restaurante">
  <div class="container">
    <div class="restaurante-content">
      <div class="restaurante-imagen">
        <img
          src="/assets/images/restaurante.webp"
          alt="Restaurante principal del Manantial Rey de Francia"
          loading="lazy"
        />
      </div>

      <div class="restaurante-info">
        <h2>Restaurante para disfrutar sin salir del complejo</h2>
        <p class="subtitle">Platos, bebidas y opciones para compartir mientras vives tu día de relajación.</p>

        <div class="menu-categories">
          <div class="category">
            <div class="category-header">
              <Icono name="comida" size="28" />
              <h4>Para comer rico</h4>
            </div>

            <ul class="menu-list">
              <li>Salchipapa</li>
              <li>Papa completa</li>
              <li>Papi carne</li>
              <li>Papi pollo</li>
              <li>Súper completa</li>
              <li>Súper menestra</li>
              <li>Churrasco</li>
            </ul>
          </div>

          <div class="category">
            <div class="category-header">
              <Icono name="bebidas" size="28" />
              <h4>Para refrescarte</h4>
            </div>

            <ul class="menu-list">
              <li>Limonada</li>
              <li>Limonada con gas</li>
              <li>Jugos naturales</li>
              <li>Sodas</li>
              <li>Bebidas isotónicas</li>
              <li>Jarras de jugo</li>
              <li>Cerveza</li>
            </ul>
          </div>
        </div>

        <div class="restaurant-highlights">
          <div class="highlight"><Icono name="check" size="24" /><span>Sabor local con precios accesibles</span></div>
          <div class="highlight"><Icono name="check" size="24" /><span>Opciones para compartir en familia</span></div>
          <div class="highlight"><Icono name="check" size="24" /><span>Servicio rápido dentro del complejo</span></div>
          <div class="highlight"><Icono name="check" size="24" /><span>Ideal para combinar con combos de relax</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .restaurante { padding: var(--spacing-2xl) var(--spacing-lg); background: linear-gradient(135deg, #f1f5f9 0%, #e0f2fe 100%); }
  .container { max-width: 1520px; margin: 0 auto; padding: 0 clamp(1rem, 2.5vw, 2rem); }
  .restaurante-content {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.4rem, 2.6vw, 2.8rem);
    align-items: stretch;
  }
  .restaurante-imagen { width: 100%; height: 100%; min-height: 520px; }
  .restaurante-imagen img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: var(--radius-xl); box-shadow: 0 8px 25px rgba(15, 23, 42, 0.15); }
  .restaurante-info { display: flex; flex-direction: column; justify-content: center; }
  .restaurante-info h2 { font-size: 2.5rem; color: var(--color-primary); margin-bottom: var(--spacing-md); }
  .subtitle { font-size: 1.15rem; color: var(--color-text-light); margin-bottom: var(--spacing-xl); }

  .menu-categories { display: grid; grid-template-columns: 1fr; gap: var(--spacing-md); margin-bottom: var(--spacing-xl); }

  .category {
    padding: var(--spacing-md);
    background: var(--color-white);
    border-radius: var(--radius-md);
    border-left: 4px solid var(--color-accent);
    transition: all 0.3s ease;
  }

  .category:hover { transform: translateX(8px); box-shadow: 0 4px 12px rgba(14, 165, 233, 0.2); }

  .category-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-sm);
  }

  .category-header :global(.icono) {
    color: var(--color-accent);
  }

  .category h4 {
    font-size: 1.1rem;
    color: var(--color-primary);
    margin: 0;
  }

  .menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 6px;
  }

  .menu-list li {
    position: relative;
    padding-left: 18px;
    font-size: 0.95rem;
    color: var(--color-text-light);
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .menu-list li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-weight: 700;
  }

  .menu-list li:hover {
    transform: translateX(4px);
    color: var(--color-primary);
  }

  .restaurant-highlights { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--spacing-md); }

  .highlight { display: flex; align-items: center; gap: var(--spacing-md); padding: var(--spacing-md); background: rgba(14, 165, 233, 0.05); border-radius: var(--radius-md); }
  .highlight :global(svg) { color: var(--color-accent); flex-shrink: 0; }
  .highlight span { color: var(--color-text); font-weight: 500; }

  @media (max-width: 768px) {
    .restaurante-content { grid-template-columns: 1fr; }
    .restaurante-imagen { min-height: 300px; }
    .restaurante-info h2 { font-size: 1.875rem; }
    .restaurant-highlights { grid-template-columns: 1fr; }

    .menu-list li {
      font-size: 0.92rem;
    }
  }
</style>

