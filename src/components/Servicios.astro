---
import Icono from "./Icono.astro";

interface Service {
  iconName: string;
  title: string;
  description: string;
}

// Definición de servicios ofrecidos por el negocio
const services: Service[] = [
  {
    iconName: "piscina", title: "Piscina",
    description: "Piscina temperada recreativas en un ambiente climatizado y seguro para disfrutar en familia o con amigos."
  },
  {
    iconName: "sauna", title: "Sauna",
    description: "Calor seco ideal para liberar tensión muscular y mejorar la recuperación física."
  },
  {
    iconName: "sauna", title: "Turco",
    description: "Baño de vapor húmedo que ayuda a relajar el cuerpo, limpiar la piel y mejorar la respiración."
  },
  {
    iconName: "piscina", title: "Hidromasaje",
    description: "Jacuzzi con chorros de agua diseñados para relajar el cuerpo y reducir el estrés."
  },
  {
    iconName: "cascada", title: "Chorros de agua",
    description: "Terapia de contraste frío-calor que estimula la circulación y revitaliza el organismo."
  },
  {
    iconName: "hotel", title: "Habitaciones",
    description: "Espacios cómodos y privados disponibles por horas para descanso, celebraciones o escapadas."
  },
  {
    iconName: "sauna", title: "Baños de cajón",
    description: "Experiencia tradicional de calor que complementa tu rutina de relajación y bienestar."
  },
  {
    iconName: "restaurant", title: "Restaurante",
    description: "Servicio gastronómico con variedad de platos y bebidas para complementar tu experiencia."
  },
  {
    iconName: "car", title: "Parqueadero",
    description: "Espacio seguro y amplio para estacionar tu vehículo con total tranquilidad."
  },
];
---

<section id="servicios" class="servicios">
  <div class="container">
    <div class="section-header">
      <span class="section-kicker">Nuestros servicios</span>
      <h2>Todo lo que puedes disfrutar en tu visita</h2>
      <p>Elige tu plan y combina agua, calor y descanso en un solo lugar.</p>
    </div>

    <div class="servicios-grid">
      {
        services.map((service) => (
          <article class="service-card">
            <div class="service-icon"><Icono name={service.iconName} size="32" /></div>
            <h3>{service.title}</h3>
            <p>{service.description}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .container {
    max-width: 1520px;
    margin: 0 auto;
    padding: 0 clamp(1rem, 2.5vw, 2rem);
  }

  .servicios {
    padding: var(--spacing-2xl) 0;
    position: relative;
    isolation: isolate;
  }

  .servicios::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(560px 260px at 8% 24%, rgba(6, 126, 255, 0.1), transparent 70%),
      radial-gradient(580px 260px at 92% 78%, rgba(72, 185, 255, 0.1), transparent 70%);
    z-index: -1;
    pointer-events: none;
  }

  .section-header h2 { color: var(--color-primary); margin: var(--spacing-md) auto; max-width: 760px; line-height: 1.18; }
  .section-header p { font-size: 1.08rem; color: var(--color-text-light); max-width: 760px; margin: 0 auto; line-height: 1.78; }

  .servicios-grid {
    display: grid;
    grid-template-columns: repeat(12, minmax(0, 1fr));
    gap: clamp(0.9rem, 1.3vw, 1.3rem);
  }

  .service-card {
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(8px);
    padding: var(--spacing-xl);
    border-radius: var(--radius-xl);
    text-align: left;
    transition: transform var(--transition-standard), border-color var(--transition-standard), box-shadow var(--transition-standard), background-color var(--transition-standard);
    border: 1px solid rgba(11, 31, 54, 0.1);
    box-shadow: 0 12px 30px rgba(11, 31, 54, 0.1);
    position: relative;
    overflow: hidden;
    grid-column: span 4;
  }

  .service-card::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-secondary));
    transform: scaleX(0.2);
    transform-origin: left;
    opacity: 0;
    transition: transform var(--transition-standard), opacity var(--transition-standard);
  }

  .service-card:hover {
    transform: translateY(-8px);
    border-color: rgba(6, 126, 255, 0.3);
    box-shadow: 0 22px 44px rgba(11, 31, 54, 0.16);
    background: rgba(255, 255, 255, 0.92);
  }

  .service-card:hover::after {
    transform: scaleX(1);
    opacity: 1;
  }

  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: 14px;
    margin-bottom: var(--spacing-md);
    color: var(--color-accent-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, rgba(6, 126, 255, 0.16) 0%, rgba(72, 185, 255, 0.2) 100%);
    box-shadow: inset 0 0 0 1px rgba(8, 84, 197, 0.1);
  }

  .service-card h3 { color: var(--color-primary); margin-bottom: var(--spacing-sm); font-size: 1.25rem; }
  .service-card p { color: var(--color-text-light); line-height: 1.65; }

  @media (max-width: 768px) {
    .servicios { padding: var(--spacing-xl) 0; }
    .servicios-grid { grid-template-columns: 1fr; }
    .service-card { grid-column: auto; }
    .section-header { margin-bottom: var(--spacing-xl); }
  }

  @media (min-width: 769px) and (max-width: 1100px) {
    .service-card {
      grid-column: span 6;
    }
  }

  @media (max-width: 260px) {
    .container {
      padding: 0 0.5rem;
    }

    .section-header h2 {
      line-height: 1.2;
    }

    .section-header p {
      font-size: 0.9rem;
      line-height: 1.5;
    }

    .service-card {
      padding: 0.75rem;
      border-radius: 0.9rem;
    }

    .service-icon {
      width: 42px;
      height: 42px;
      border-radius: 10px;
      margin-bottom: 0.55rem;
    }

    .service-card h3 {
      font-size: 0.98rem;
      margin-bottom: 0.35rem;
    }

    .service-card p {
      font-size: 0.82rem;
      line-height: 1.42;
    }
  }
</style>
