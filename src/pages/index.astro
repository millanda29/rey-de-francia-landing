---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navigation from "../components/Navigation.astro";
import Hero from "../components/Hero.astro";
import Servicios from "../components/Servicios.astro";
import BeneficiosDetallados from "../components/BeneficiosDetallados.astro";
import Instalaciones from "../components/Instalaciones.astro";
import Restaurante from "../components/Restaurante.astro";
import Combos from "../components/Combos.astro";
import Tarifas from "../components/Tarifas.astro";
import Mapa from "../components/Mapa.astro";
import Horarios from "../components/Horarios.astro";
import Testimonios from "../components/Testimonios.astro";
import FAQ from "../components/FAQ.astro";
import Reservas from "../components/Reservas.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Manantial Rey de Francia | Hostal y Piscinas en Chillogallo, Quito"
  description="Relájate en Manantial Rey de Francia: piscina temperada, sauna, turco, hidromasaje y hospedaje en Chillogallo, Quito. Reserva fácil por WhatsApp."
  image="/assets/images/piscina.webp"
  keywords="hostal y piscinas quito, piscina temperada chillogallo, sauna turco quito, hidromasaje quito, reservas hostal quito"
>
  <Navigation />
  <Hero />
  <Servicios />
  <BeneficiosDetallados />
  <Instalaciones />
  <Restaurante />
  <Combos />
  <Tarifas />
  <Mapa />
  <Horarios />
  <Testimonios />
  <FAQ />
  <Reservas />
  <Footer />
</BaseLayout>


